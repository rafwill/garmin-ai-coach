# Credenciales — nunca subir al repo
.env

# Certificado corporativo (específico del entorno)
# Regenerar con: Export-Certificate -Cert (Get-ChildItem Cert:\LocalMachine\Root | Where Subject -like "*Zscaler*") -FilePath zscaler-ca.pem
zscaler-ca.pem

# Tokens OAuth de Garmin (guardados localmente por el MCP)
.garmin-mcp/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.venv2/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# Node
node_modules/

# VS Code (configuración local de cada desarrollador)
.vscode/

# Runtime local (no versionar)
agent.log

# Memoria local del usuario (puede contener datos personales)
memory/*
!memory/.gitkeep

# OS
.DS_Store
Thumbs.db
