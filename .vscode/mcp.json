{
  "servers": {
    "garmin": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@nicolasvegam/garmin-connect-mcp@latest"],
      "env": {
        "GARMIN_EMAIL": "${input:garminEmail}",
        "GARMIN_PASSWORD": "${input:garminPassword}"
      }
    }
  },
  "inputs": [
    {
      "id": "garminEmail",
      "type": "promptString",
      "description": "Garmin Connect email",
      "password": false
    },
    {
      "id": "garminPassword",
      "type": "promptString",
      "description": "Garmin Connect password",
      "password": true
    }
  ]
}
