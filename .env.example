# ─── Garmin Connect ───────────────────────────────────────────────────────────
GARMIN_EMAIL=tu_email@ejemplo.com
GARMIN_PASSWORD=tu_contraseña

# ─── LLM Provider: DENTRO de VPN (Zscaler) ───────────────────────────────────
# GitHub Models — gratuito con cuenta GitHub
# Obtener token en: https://github.com/settings/tokens
# Solo necesita scope: (ninguno, el acceso a Models es público con cualquier token)
GITHUB_TOKEN=ghp_...
# Modelos disponibles (todos gratuitos):
# gpt-4o-mini   → rápido, ideal para este agente
# gpt-4o        → mejor calidad
# meta-llama-3.1-70b-instruct
GITHUB_MODEL=gpt-4o-mini

# ─── LLM Provider: FUERA de VPN — opción 1 ───────────────────────────────────
# Groq — gratuito, 100k tokens/día, API compatible con OpenAI
# Registro en: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── LLM Provider: FUERA de VPN — opción 2 (RECOMENDADA) ─────────────────────
# Google AI Studio / Gemini — gratuito, ~1M tokens/día, API compatible con OpenAI
# Registro en: https://aistudio.google.com → Get API key (no requiere tarjeta)
GEMINI_API_KEY=AIzaSy_tu_clave_de_gemini
# Modelos disponibles (gratuitos):
# gemini-2.5-flash       → rápido, alta calidad, ventana de contexto grande ← recomendado
# gemini-2.5-flash-lite  → más ligero y rápido
# gemini-1.5-pro         → máxima calidad, más lento
GEMINI_MODEL=gemini-2.0-flash

# ─── Supabase (opcional) ─────────────────────────────────────────────
# Si se configuran, la memoria del agente (perfil, historial, cuota Gemini)
# se guarda en PostgreSQL gestionado en la nube en vez de en ficheros JSON locales.
# Los ficheros JSON se siguen escribiendo como backup offline.
#
# Pasos:
#   1. Crea un proyecto en https://supabase.com (capa gratuita: 500 MB)
#   2. En el dashboard: Settings → API → copia Project URL y anon public key
#   3. Ejecuta supabase/schema.sql en: SQL Editor → New query → Run
#
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Configuración del agente ─────────────────────────────────────────────────
# Herramientas habilitadas para el agente (separadas por coma)
# Omitir para usar el conjunto por defecto (~28 herramientas esenciales)
# Usar "all" para cargar las 126 herramientas (más tokens por petición)
# GARMIN_ENABLED_TOOLS=get_steps_data,get_daily_sleep,get_activities
